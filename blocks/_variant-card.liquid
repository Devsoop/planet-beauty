

{% liquid
  assign product = closest.product
  assign variant_resource = variant | default: closest.product.selected_or_first_available_variant
-%}

{% render 'variant-card', product: product, variant: variant_resource, section: section, block: block %}

{% schema %}
{
  "name": "Variant card",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "Settings for variant cards rendered in collection variant mode."
    },
    {
      "type": "select",
      "id": "title_type_preset",
      "label": "Title preset",
      "options": [
        { "value": "rte", "label": "Default" },
        { "value": "paragraph", "label": "Paragraph" },
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ],
      "default": "rte"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "select",
      "id": "price_type_preset",
      "label": "Price preset",
      "options": [
        { "value": "rte", "label": "Default" },
        { "value": "paragraph", "label": "Paragraph" },
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ],
      "default": "h6",
      "visible_if": "{{ block.settings.show_price }}"
    },
    {
      "type": "select",
      "id": "title_source",
      "label": "Title source",
      "options": [
        { "value": "product", "label": "Product" },
        { "value": "variant", "label": "Variant" }
      ],
      "default": "variant"
    },
    {
      "type": "select",
      "id": "image_source",
      "label": "Image source",
      "options": [
        { "value": "variant", "label": "Variant" },
        { "value": "product", "label": "Product" }
      ],
      "default": "variant"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "adapt", "label": "Adapt" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" },
        { "value": "landscape", "label": "Landscape" }
      ],
      "default": "adapt"
    }
  ]
}
{% endschema %}
