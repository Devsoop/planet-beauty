
{% render 'button', link: block.settings.link %}

{% schema %}
{
  "name": "t:names.button",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "t:settings.label",
      "default": "t:text_defaults.button_label"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:settings.link",
      "visible_if": "{{ block.settings.enable_buy_now == false }}"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "t:settings.open_new_tab",
      "default": false,
      "visible_if": "{{ block.settings.enable_buy_now == false }}"
    },
    {
      "type": "header",
      "content": "Buy Now Button"
    },
    {
      "type": "checkbox",
      "id": "enable_buy_now",
      "label": "Enable Buy Now",
      "default": false,
      "info": "When enabled, clicking this button will add the product to cart."
    },
    {
      "type": "select",
      "id": "buy_now_action",
      "label": "Action after clicking",
      "options": [
        {
          "value": "checkout",
          "label": "Go to checkout"
        },
        {
          "value": "add_to_cart",
          "label": "Only add to cart"
        }
      ],
      "default": "checkout",
      "visible_if": "{{ block.settings.enable_buy_now }}"
    },
    {
      "type": "text",
      "id": "variant_id",
      "label": "Product Variant ID",
      "info": "Enter the Shopify variant ID (numeric)",
      "visible_if": "{{ block.settings.enable_buy_now }}"
    },
    {
      "type": "select",
      "id": "style_class",
      "label": "t:settings.style",
      "options": [
        {
          "value": "button",
          "label": "t:options.primary"
        },
        {
          "value": "button-secondary",
          "label": "t:options.secondary"
        },
        {
          "value": "link",
          "label": "t:options.link"
        }
      ],
      "default": "button"
    },
    {
      "type": "header",
      "content": "Link style",
      "visible_if": "{{ block.settings.style_class == \"link\" }}"
    },
    {
      "type": "checkbox",
      "id": "link_underlined",
      "label": "Underline",
      "default": false,
      "visible_if": "{{ block.settings.style_class == \"link\" }}"
    },
    {
      "type": "select",
      "id": "link_font_style",
      "label": "Font style",
      "options": [
        {
          "value": "normal",
          "label": "Normal"
        },
        {
          "value": "italic",
          "label": "Italic"
        }
      ],
      "default": "normal",
      "visible_if": "{{ block.settings.style_class == \"link\" }}"
    },
    {
      "type": "select",
      "id": "link_font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Regular (400)"
        },
        {
          "value": "500",
          "label": "Medium (500)"
        },
        {
          "value": "600",
          "label": "Semi-bold (600)"
        },
        {
          "value": "700",
          "label": "Bold (700)"
        }
      ],
      "default": "400",
      "visible_if": "{{ block.settings.style_class == \"link\" }}"
    },
    {
      "type": "range",
      "id": "link_letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 5,
      "step": 0.1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ block.settings.style_class == \"link\" }}"
    },
    {
      "type": "range",
      "id": "link_font_size",
      "label": "Font size",
      "min": 10,
      "max": 72,
      "step": 1,
      "unit": "px",
      "default": 16,
      "visible_if": "{{ block.settings.style_class == \"link\" }}"
    },
    {
      "type": "range",
      "id": "link_font_size_mobile",
      "label": "Font size mobile",
      "min": 10,
      "max": 72,
      "step": 1,
      "unit": "px",
      "default": 16,
      "visible_if": "{{ block.settings.style_class == \"link\" }}"
    },
    {
      "type": "header",
      "content": "t:content.size"
    },
    {
      "type": "select",
      "id": "width",
      "label": "t:settings.width_desktop",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit_content"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "t:settings.custom_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width == \"custom\" }}"
    },
    {
      "type": "select",
      "id": "width_mobile",
      "label": "t:settings.width_mobile",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit_content"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width_mobile",
      "label": "t:settings.custom_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width_mobile == \"custom\" }}"
    }
  ],
  "presets": [
    {
      "name": "t:names.button",
      "category": "t:categories.basic",
      "settings": {
        "link": "shopify://collections/all"
      }
    }
  ]
}
{% endschema %}
