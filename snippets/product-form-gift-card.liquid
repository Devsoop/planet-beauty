<div class="product-form">

  {% form 'product', product, class:form_classes, novalidate: 'novalidate', data-product-form: '' %}

    <!-- Begin ReCharge code -->
    {% if product.available %}{% render 'subscription-product' with product as product %}{% endif %}
    <!-- End ReCharge code -->

    {% comment %}
      Automatically inserted by Shop Pay Installments theme updater
    {% endcomment %}
    {% unless settings.disable_autogenerated_payment_terms %}
      {{ form | payment_terms }}
    {% endunless %}

    {% if product.type == 'Gift Card' %}
      <div class="product-form__swatches">
        {% render 'product-swatches', product: product %}
      </div>
    {% endif %}

    <div class="product-form__options">
      {% render 'product-options', product: product %}
    </div>

    {% if product.available %}
      <div class="product-single__store-availability-container"
      data-store-availability-container
      data-product-title=""
      data-has-only-default-variant=""
      data-base-url="">
        <div class="loading-text loading-text__medium"></div>
      </div>
    {% endif %}
    
    {% if product.type != 'Gift Card' %}
      <div class="product-form__swatches">
        {% render 'product-swatches', product: product %}
      </div>
    {% endif %}
    {% render 'product-form-giftcard', product: product %}
    <div class="product-form__controls">

      <div class="product-form__quantity">
        {% render 'quantity-selector', value: 1, name: 'quantity' %}
      </div>

      <div class="product-form__buttons">

        <button type="submit" name="add" class="trr product-form__button btn btn-secondary btn-icon btn-icon-before btn-loading {% unless product.available %}active{% endunless %}" data-swatches-add-to-card {% unless product.available %}disabled{% endunless %}>
          <div class="product-form__button--out-of-stock" data-swatches-out-of-stock>
            {% render 'icon-bag' %}
            {{ 'products.product.sold_out' | t }}
          </div>
          <div class="product-form__button--add-to-cart-content" data-add-to-card-content>
            {% render 'icon-bag' %}
            {% render 'icon-loading' %}
            {{ 'products.product.add_to_cart' | t }}
          </div>
        </button>

      </div>
      
    </div>

    <span class="product-form__error-message" data-error-message></span>

  {% endform %}

</div>
<script>
document.addEventListener('DOMContentLoaded', function () {
  const productForm = document.querySelector('.product-form');
  const gcForm = productForm?.querySelector('.gc_form_main');

  // Only run if gift card form exists
  if (!gcForm) return;

  const addToCartBtn = productForm.querySelector('[data-swatches-add-to-card]');
  const requiredFields = gcForm.querySelectorAll('input.required');

  function allFieldsFilled() {
    return Array.from(requiredFields).every((input) => input.value.trim() !== '');
  }

  function toggleButtonState() {
    if (allFieldsFilled()) {
      addToCartBtn.classList.remove('disabled');
      addToCartBtn.removeAttribute('aria-disabled');
      addToCartBtn.removeAttribute('disabled');
    } else {
      addToCartBtn.classList.add('disabled');
      addToCartBtn.setAttribute('aria-disabled', 'true');
      addToCartBtn.setAttribute('disabled', 'disabled');
    }
  }

  // Initial state
  toggleButtonState();

  // Monitor field changes
  requiredFields.forEach((field) => {
    field.addEventListener('input', toggleButtonState);
  });

  // Prevent AJAX add-to-cart if fields not filled
  addToCartBtn.addEventListener('click', function (e) {
    if (!allFieldsFilled()) {
      e.preventDefault();
      e.stopImmediatePropagation(); // stop AJAX handlers
      const errMsg = productForm.querySelector('[data-error-message]');
      if (errMsg) errMsg.textContent = 'Please fill all required gift card fields.';
      requiredFields.forEach((f) => {
        if (!f.value.trim()) f.classList.add('field-error');
      });
    }
  });
});


</script>