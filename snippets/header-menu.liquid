{% liquid
  assign menu_content_type = settings.menu_style | default: 'text'
  assign image_border_radius = settings.image_border_radius
  assign color_scheme_classes = ''
  assign color_scheme_setting_id = 'color_scheme_' | append: section.settings.menu_row
  assign current_color_scheme = settings.color_scheme
  assign parent_color_scheme = section.settings[color_scheme_setting_id]

  if parent_color_scheme.id != current_color_scheme.id
    assign color_scheme_classes = ' color-' | append: current_color_scheme
  endif

  # Check if header and menu colors match. This is used to apply different padding styles in css
  if parent_color_scheme.settings.background.rgb == current_color_scheme.settings.background.rgb
    assign color_scheme_classes = color_scheme_classes | append: ' color-scheme-matches-parent'
  endif

  if settings.menu_style == 'featured_collections'
    assign ratio = settings.featured_collections_aspect_ratio
  elsif settings.menu_style == 'featured_products'
    assign ratio = settings.featured_products_aspect_ratio
  endif
%}

{% capture children %}
  {% for link in settings.menu.links %}
    <li
      role="presentation"
      class="menu-list__list-item"
      on:focus="/activate"
      on:blur="/deactivate"
      on:pointerenter="/activate"
      on:pointerleave="/deactivate"
    >
      <a
        href="{{ link.url }}"
        class="menu-list__link{% if link.active %} menu-list__link--active{% endif %}"
        {%- if link.links != blank -%}
          aria-controls="submenu-{{ forloop.index }}"
          aria-haspopup="true"
          aria-expanded="false"
        {%- endif -%}
        ref="menuitem"
      >
        <span class="menu-list__link-title">{{- link.title -}}</span>
      </a>
      {%- if link.links != blank -%}
        <div class="menu-list__submenu{{ color_scheme_classes }}" ref="submenu[]">
          <div
            id="submenu-{{ forloop.index }}"
            class="menu-list__submenu-inner"
            style="{% render 'submenu-font-styles', settings: settings %}"
          >
          {% if section.settings.menu_style == 'custom_content' %}
            {%- liquid
                assign detailed_collection_block = null
                assign current_nav_link_handle = link.title | handleize

                for block_item in section.blocks
                  if block_item.type == 'detailed_collection_menu'
                    assign parent_block_link_handle = block_item.settings.title | handleize
                    if current_nav_link_handle == parent_block_link_handle
                      assign detailed_collection_block = block_item
                      break
                    endif
                  endif
                endfor
              -%}

              {%- if detailed_collection_block -%}
                {% comment %} Render detailed collection menu (two-pane or children-only horizontal cards) {% endcomment %}
                {% render 'detailed-collection-mega-menu', current_link_object: link, current_section_object: section, menu_block: detailed_collection_block %}
              {%- else -%}
                {% comment %} Original mega menu list rendering - now from its own snippet {% endcomment %}
                {%- liquid
                  assign columns_for_layout = '6'
                  assign product_block_to_render = null
                  assign current_link_handle_for_product_block = link.title | handleize
            
            
                  for block_check in section.blocks
                    if block_check.type == 'product'
                      assign parent_link_handle_check = block_check.settings.title | handleize
                      if current_link_handle_for_product_block == parent_link_handle_check
                        assign columns_for_layout = block_check.settings.mega-pane-columns | default: '6'
                        assign product_block_to_render = block_check
                        break
                      endif
                    endif
                  endfor
                -%}
                {% render 'product-mega-menu-content', current_link_object: link, layout_columns: columns_for_layout, featured_block: product_block_to_render %}
              {%- endif -%}
              
          {% else %}
            {% assign list_id = 'MegaMenuList-' | append: forloop.index %}
            {% render 'mega-menu',
              parent_link: link,
              id: list_id,
              menu_content_type: menu_content_type,
              content_aspect_ratio: ratio,
              image_border_radius: image_border_radius
            %}
          {%endif%}
          </div>
        </div>
      {%- endif -%}
    </li>
  {% endfor %}
  <li
    class="menu-list__list-item"
    role="presentation"
    slot="more"
    on:focus="/activate"
    on:blur="/deactivate"
    on:pointerenter="/activate"
    on:pointerleave="/deactivate"
  >
    <button role="menuitem" class="button menu-list__link button-unstyled">
      <span class="menu-list__link-title">{{ 'actions.more' | t }}</span>
    </button>
  </li>
{% endcapture %}

<nav header-menu>
  <div
    class="menu-list"
    style="{% render 'menu-font-styles', settings: settings %}"
  >
    {% assign class = 'overflow-menu' | append: color_scheme_classes %}
    {% render 'overflow-list', class: class, ref: 'overflowMenu', children: children, minimum-items: 2 %}
  </div>
</nav>
