{%- comment -%}
  Mega Menu Featured Content Snippet
  Renders either individual promo items or a featured collection grid.

  Accepts:
  - block: The section block object containing settings.
  - loading: (Optional) Image loading attribute, e.g., 'lazy'.
  - fetchpriority: (Optional) Image fetchpriority attribute, e.g., 'high'.
{%- endcomment -%}
<style>
  .swiper-button-next:after, .swiper-button-prev:after {
    --swiper-navigation-size: 15px;
    color: black;
  }
  .swiper-button-next svg, .swiper-button-prev svg{
    display: none;
  }
  .swiper-button-prev{
    left: 0;
  }
  .swiper-button-next{
    right: 25px;
  }
  .swiper-button-prev, .swiper-button-next {
    background: white;
    border-radius: 50px;
    width: 30px;
    height: 30px;
}
</style>
{%- liquid
  assign display_type = block.settings.content_display_type | default: 'items'
  assign parent_menu_total_columns = block.settings.mega-pane-columns | default: 6
-%}

{%- if display_type == 'collection' -%}
  {%- liquid
    assign promo_collection = block.settings.promo_collection
    assign product_limit = block.settings.promo_collection_product_limit | default: 3
    assign products_per_row = block.settings.promo_collection_products_per_row | default: 3
    assign collection_wrapper_span = block.settings.collection_wrapper_column_span | default: 3

    assign wrapper_column_class = 'mega-menu__collection-wrapper--span-' | append: collection_wrapper_span
    assign product_card_column_class = 'featured-collection__product--cols-' | append: products_per_row
  -%}

  {%- if promo_collection != blank and promo_collection.products.size > 0 -%}
    <li class="mega-menu__list-item mega-menu__list-item--collection-wrapper {{ wrapper_column_class }}">
      <div class="featured-collection">
        <div class="featured-collection__grid list-unstyled featured-slider mega-menu__slider swiper" 
            role="list"
            data-products-per-row="{{ products_per_row }}">
          <div class="swiper-wrapper">
            {%- for product in promo_collection.products limit: product_limit -%}
              <div class="featured-collection__item swiper-slide">
                <div class="featured-collection__item-inner">
                  <a href="{{ product.url }}" class="product-card">
                    <img 
                      src="{{ product.featured_image | img_url: '300x300', crop: 'center' }}"
                      alt="{{ product.title }}"
                      class="product-card__image"
                      width="300"
                      height="300"
                      loading="lazy"
                    >
                    <div class="mega-menu-card-info">
                      <h3 class="product-card__title">{{ product.title }}</h3>
                      <div class="product-card__price">
                        {%- if product.compare_at_price > product.price -%}
                          <s>{{ product.compare_at_price | money }}</s>
                        {%- endif -%}
                        {{ product.price | money }}
                      </div>
                    </div>
                  </a>
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </li>
  {%- endif -%}

{%- else -%}
  {%- comment -%} Original Individual Items Display {%- endcomment -%}
  {%- for i in (1..3) -%}
    {%- capture featured_link_key -%}featured_link_{{ i }}{%- endcapture -%}
    {%- capture featured_image_key -%}featured_image_{{ i }}{%- endcapture -%}
    {%- capture featured_title_key -%}featured_title_{{ i }}{%- endcapture -%}
    {%- capture featured_subtitle_key -%}featured_subtitle_{{ i }}{%- endcapture -%}

    {%- assign featured_image = block.settings[featured_image_key] -%}
    {%- if featured_image != blank or block.settings[featured_title_key] != blank -%}
      <li class="mega-menu__list-item mega-menu__list-item--promo-card">
        <div class="mega-menu-card">
          <a href="{{ block.settings[featured_link_key] }}" class="mega-menu-card-link">
            {%- if featured_image != blank -%}
            {{-
              featured_image
              | image_url: width: 800
              | image_tag:
                loading: loading,
                fetchpriority: fetchpriority,
                sizes: '(min-width: 990px) 800px, 500px',
                widths: '500,600,700,800,900,1000,1200,1400,1600'
            -}}
            {%- endif -%}
            <div class="mega-menu-card-content">
              <h4 class="mega-card-title">{{ block.settings[featured_title_key] }}</h4>
              <p class="mega-card-subtitle">{{ block.settings[featured_subtitle_key] }}</p>
              <div class="mob-svg">
                <svg width="24" height="21" viewBox="0 0 24 22" fill="none" xmlns="http://www.w3.org/2000/svg" class=""><path d="M13.207 0.292969L11.793 1.70697L20.0855 9.99997H0V12H20.0855L11.793 20.293L13.207 21.707L23.9145 11L13.207 0.292969Z" fill="#222222"></path></svg>
              </div>
            </div>
          </a>
        </div>
      </li>
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}
