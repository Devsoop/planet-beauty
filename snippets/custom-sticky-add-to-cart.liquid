{% comment %}
  Renders custom sticky add to cart bar
  Accepts:
  - product: {Object} product object.
  - section_id: {String} The section ID.
  - position: {String} The position of the sticky bar (top or bottom).
  - show_image: {Boolean} Whether to show the product image.
  - color_scheme: {String} The color scheme ID.
  - mobile_only_button: {Boolean} Whether to show only button on mobile.

  Usage:
  {% render 'custom-sticky-add-to-cart', product: product, section_id: section.id, position: section.settings.custom_sticky_position, show_image: section.settings.custom_sticky_show_image, color_scheme: section.settings.color_scheme, mobile_only_button: section.settings.custom_sticky_mobile_only_button %}
{% endcomment %}

{{ 'custom-sticky-add-to-cart.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured_media = current_variant.featured_media | default: product.featured_media
  assign color_scheme = color_scheme | default: settings.popover_color_scheme | default: 'scheme-1'
-%}

<custom-sticky-add-to-cart class="custom-sticky-add-to-cart color-{{ color_scheme }}{% if position == 'top' %} custom-sticky-add-to-cart--top{% else %} custom-sticky-add-to-cart--bottom{% endif %}{% if mobile_only_button %} custom-sticky-add-to-cart--mobile-button-only{% endif %}" data-section-id="{{ section_id }}" data-position="{{ position | default: 'bottom' }}">
  <div class="sticky-inner-container">
    <div class="sticky-add-to-cart__product">
      {% if show_image and featured_media %}
        <div class="sticky-add-to-cart__image">
          <img
            src="{{ featured_media | image_url: width: 120 }}"
            alt="{{ featured_media.alt | escape | default: product.title }}"
            width="60"
            height="60"
            loading="lazy"
          >
        </div>
      {% endif %}
      <div class="sticky-add-to-cart__content">
        <h3 class="sticky-add-to-cart__title">{{ product.title }}</h3>
        <div class="sticky-add-to-cart__price">
          {%- render 'price',
            product_resource: product,
            show_sale_price_first: true
          -%}
        </div>
      </div>
    </div>
    
    {% unless product.has_only_default_variant %}
      <div class="sticky-add-to-cart__variants">
        {%- for product_option in product.options_with_values -%}
          {%- liquid
            assign swatch_count = product_option.values | map: 'swatch' | compact | size
          -%}
          
          <div class="sticky-variant-group">
            <span class="sticky-variant-label">{{ product_option.name | escape }}:</span>
            
            {%- if swatch_count > 0 -%}
              <div class="sticky-variant-swatches">
                {%- for product_option_value in product_option.values -%}
                  <label class="sticky-swatch-label{% if product_option_value.selected %} is-selected{% endif %}{% if product_option_value.available == false %} is-unavailable{% endif %}">
                    <input
                      type="radio"
                      class="sticky-swatch-input visually-hidden"
                      name="sticky-{{ product_option.name | escape }}-{{ section_id }}"
                      value="{{ product_option_value | escape }}"
                      data-option-value-id="{{ product_option_value.id }}"
                      data-option-position="{{ product_option.position }}"
                      {% if product_option_value.variant.id %}
                        data-variant-id="{{ product_option_value.variant.id }}"
                      {% endif %}
                      {% if product_option_value.selected %}
                        checked
                      {% endif %}
                      {% if product_option_value.available == false %}
                        disabled
                      {% endif %}
                    >
                    {% if product_option_value.swatch %}
                      {% render 'swatch',
                        swatch: product_option_value.swatch,
                        mode: 'unscaled'
                      %}
                    {% else %}
                      <span class="sticky-swatch-text">{{ product_option_value | escape }}</span>
                    {% endif %}
                  </label>
                {%- endfor -%}
              </div>
            {%- else -%}
              <div class="sticky-variant-select-wrapper">
                <select
                  class="sticky-variant-select"
                  name="sticky-options-{{ product_option.name | escape }}-{{ section_id }}"
                  data-option-position="{{ product_option.position }}"
                >
                  {%- for product_option_value in product_option.values -%}
                    <option
                      value="{{ product_option_value | escape }}"
                      data-option-value-id="{{ product_option_value.id }}"
                      {% if product_option_value.variant.id %}
                        data-variant-id="{{ product_option_value.variant.id }}"
                      {% endif %}
                      {% if product_option_value.selected %}
                        selected="selected"
                      {% endif %}
                      {% if product_option_value.available == false %}
                        disabled
                      {% endif %}
                    >
                      {{ product_option_value | escape }}{% if product_option_value.available == false %} - {{ 'content.unavailable' | t }}{% endif %}
                    </option>
                  {%- endfor -%}
                </select>
                <svg class="sticky-select-icon" viewBox="0 0 10 6" aria-hidden="true">
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {% endunless %}

    <div class="sticky-add-to-cart__actions">
      {% if product.available and mobile_only_button == false %}
        <div class="sticky-quantity-wrapper">
          {%- render 'quantity-selector',
            variant: current_variant,
            class: 'quantity-selector--sticky'
          -%}
        </div>
      {% endif %}
      
      <div class="sticky-button-wrapper">
        <input type="hidden" name="id" value="{{ current_variant.id }}">
        <button
          type="button"
          name="add"
          class="sticky-add-button"
          {% if current_variant.available == false %}
            disabled
          {% endif %}
        >
          <span>
            {%- if current_variant.available -%}
              {{ 'products.product.add_to_cart' | t }}
            {%- else -%}
              {{ 'products.product.sold_out' | t }}
            {%- endif -%}
          </span>
        </button>
      </div>
    </div>
  </div>
</custom-sticky-add-to-cart>

