{% comment %}
  Renders a detailed collection mega menu.
  - When all children have no grandchildren: single pane, horizontal image cards (uses block columns).
  - Otherwise: two-pane (left nav + right content).
  Accepts:
  - current_link_object: The parent navigation link object.
  - current_section_object: The section object (for settings like color_scheme).
  - menu_block: Optional block with settings (e.g. mega-pane-columns for children-only layout).
{% endcomment %}

{%- liquid
  assign has_any_grandchildren = false
  for childlink in current_link_object.links
    if childlink.links != blank
      assign has_any_grandchildren = true
      break
    endif
  endfor
  assign columns_count = 6
  if menu_block and menu_block.settings['mega-pane-columns']
    assign columns_count = menu_block.settings['mega-pane-columns']
  endif
-%}

{%- if has_any_grandchildren == false -%}
  {%- comment -%} Children only: no left panel, horizontal image cards with block columns {%- endcomment -%}
  <div class="detailed-mega-menu detailed-mega-menu--children-only page-width" data-parent-link-handle="{{ current_link_object.handle }}" style="--detailed-menu-columns: {{ columns_count }};">
    <ul class="detailed-mega-menu__cards-grid" role="list">
      {%- for childlink in current_link_object.links -%}
        <li>
          <a href="{{ childlink.url }}" class="detailed-mega-menu__grandchild-link">
            {%- liquid
              assign link_image = null
              assign link_show_placeholder = false
              assign link_alt = childlink.title | escape

              case childlink.type
              when 'collection_link'
                assign link_show_placeholder = true
                assign c = childlink.object
                if c.products.first and c.products.first.featured_image
                  assign link_image = c.products.first.featured_image
                elsif c.image
                  assign link_image = c.image
                endif
              when 'product_link'
                assign link_show_placeholder = true
                assign p = childlink.object
                if p.featured_image
                  assign link_image = p.featured_image
                endif
              when 'article_link'
                assign link_show_placeholder = true
                assign a = childlink.object
                if a.featured_image
                  assign link_image = a.featured_image
                endif
              when 'page_link'
                assign pg = childlink.object
                if pg.image
                  assign link_image = pg.image
                endif
              endcase
            -%}
            {%- if link_image -%}
              <img
                src="{{ link_image | remove_first: 'files/' | file_url }}"
                alt="{{ link_alt }}"
                class="detailed-mega-menu__grandchild-image"
                width="100"
                height="100"
                loading="lazy"
              >
            {%- elsif link_show_placeholder -%}
              <div class="detailed-mega-menu__grandchild-image-placeholder">
                {{- 'icon-image.svg' | inline_asset_content -}}
              </div>
            {%- endif -%}
            <span>{{ childlink.title | escape }}</span>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </div>
{%- else -%}
<div class="detailed-mega-menu page-width" data-parent-link-handle="{{ current_link_object.handle }}" style="--detailed-menu-columns: {{ columns_count }};">
  <div class="detailed-mega-menu__left-pane">
    <ul role="list">
      {%- for childlink in current_link_object.links -%}
        <li
          data-childlink-handle="{{ childlink.handle }}"
          data-grandchild-target="grandchild-list-{{ current_link_object.handle }}-{{ childlink.handle }}"
          {% if childlink.links == blank %}data-has-grandchild="false" data-parent-only-target="parent-only-{{ current_link_object.handle }}-{{ childlink.handle }}"{% else %}data-has-grandchild="true"{% endif %}
        >
          <a
            href="{{ childlink.url }}"
            class="detailed-mega-menu__child-link mega-menu__link mega-menu__link--parent {% if childlink.links == blank %}detailed-mega-menu__child-link--no-children{% endif %}"
          >
            {{ childlink.title | escape }}
            {%- if childlink.links != blank -%}
              {{- 'icon-caret.svg' | inline_asset_content -}}
            {%- endif -%}
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </div>
  <div class="detailed-mega-menu__right-pane">
    {%- for childlink in current_link_object.links -%}
      {%- if childlink.links != blank -%}
        <div
          class="detailed-mega-menu__grandchild-list"
          id="grandchild-list-{{ current_link_object.handle }}-{{ childlink.handle }}"
          style="display: none;"
        >
          <ul role="list">
            {%- for grandchildlink in childlink.links -%}
              <li>
                <a href="{{ grandchildlink.url }}" class="detailed-mega-menu__grandchild-link">
                  {%- liquid
                    assign link_image = null
                    assign link_show_placeholder = false
                    assign link_alt = grandchildlink.title | escape

                    case grandchildlink.type
                    when 'collection_link'
                      assign link_show_placeholder = true
                      assign c = grandchildlink.object
                      if c.products.first and c.products.first.featured_image
                        assign link_image = c.products.first.featured_image
                      elsif c.image
                        assign link_image = c.image
                      endif
                    when 'product_link'
                      assign link_show_placeholder = true
                      assign p = grandchildlink.object
                      if p.featured_image
                        assign link_image = p.featured_image
                      endif
                    when 'article_link'
                      assign link_show_placeholder = true
                      assign a = grandchildlink.object
                      if a.featured_image
                        assign link_image = a.featured_image
                      endif
                    when 'page_link'
                      assign pg = grandchildlink.object
                      if pg.image
                        assign link_image = pg.image
                      endif
                    endcase
                  -%}
                  {%- if link_image -%}
                    <img
                      src="{{ link_image | remove_first: 'files/' | file_url }}"
                      alt="{{ link_alt }}"
                      class="detailed-mega-menu__grandchild-image"
                      width="100"
                      height="100"
                      loading="lazy"
                    >
                  {%- elsif link_show_placeholder -%}
                    <div class="detailed-mega-menu__grandchild-image-placeholder">
                      {{- 'icon-image.svg' | inline_asset_content -}}
                    </div>
                  {%- endif -%}
                  <span>{{ grandchildlink.title | escape }}</span>
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- else -%}
        {%- comment -%} No grandchildren: show parent collection/product image in right pane {%- endcomment -%}
        <div
          class="detailed-mega-menu__parent-only detailed-mega-menu__grandchild-list"
          id="parent-only-{{ current_link_object.handle }}-{{ childlink.handle }}"
          style="display: none;"
        >
          <ul role="list">
            <li>
              <a href="{{ childlink.url }}" class="detailed-mega-menu__grandchild-link">
                {%- liquid
                  assign link_image = null
                  assign link_show_placeholder = false
                  assign link_alt = childlink.title | escape

                  case childlink.type
                  when 'collection_link'
                    assign link_show_placeholder = true
                    assign c = childlink.object
                    if c.products.first and c.products.first.featured_image
                      assign link_image = c.products.first.featured_image
                    elsif c.image
                      assign link_image = c.image
                    endif
                  when 'product_link'
                    assign link_show_placeholder = true
                    assign p = childlink.object
                    if p.featured_image
                      assign link_image = p.featured_image
                    endif
                  when 'article_link'
                    assign link_show_placeholder = true
                    assign a = childlink.object
                    if a.featured_image
                      assign link_image = a.featured_image
                    endif
                  when 'page_link'
                    assign pg = childlink.object
                    if pg.image
                      assign link_image = pg.image
                    endif
                  endcase
                -%}
                {%- if link_image -%}
                  <img
                    src="{{ link_image | remove_first: 'files/' | file_url }}"
                    alt="{{ link_alt }}"
                    class="detailed-mega-menu__grandchild-image"
                    width="100"
                    height="100"
                    loading="lazy"
                  >
                {%- elsif link_show_placeholder -%}
                  <div class="detailed-mega-menu__grandchild-image-placeholder">
                    {{- 'icon-image.svg' | inline_asset_content -}}
                  </div>
                {%- endif -%}
                <span>{{ childlink.title | escape }}</span>
              </a>
            </li>
          </ul>
        </div>
      {%- endif -%}
    {%- endfor -%}
      <div class="detailed-mega-menu__right-pane-default-message" style="display: none;">
      Select an item from the left to see more.
    </div>
  </div>
</div>
{%- endif -%}

<script>
document.addEventListener('DOMContentLoaded', () => {
  // Use a more specific selector if this script is part of a snippet rendered multiple times
  // For now, assuming it's unique enough or the logic within handles multiple instances correctly.
  const setupDetailedMegaMenu = (menuElement) => {
    console.log('Detailed Mega Menu JS: Initializing a menu element.');
    const leftPaneListItems = menuElement.querySelectorAll('.detailed-mega-menu__left-pane > ul > li');
    const rightPane = menuElement.querySelector('.detailed-mega-menu__right-pane');
    const defaultMessage = rightPane ? rightPane.querySelector('.detailed-mega-menu__right-pane-default-message') : null;
    let activeRightPanel = null;
    let activeChildLink = null;

    if (!rightPane) {
        console.error('Detailed Mega Menu JS: Menu is missing .detailed-mega-menu__right-pane');
        return;
    }
    if (!defaultMessage) {
        console.warn('Detailed Mega Menu JS: Menu is missing .detailed-mega-menu__right-pane-default-message');
    }

    const showDefaultMessage = () => {
      if (defaultMessage) {
        defaultMessage.style.display = 'flex';
      }
    };
    const hideDefaultMessage = () => {
      if (defaultMessage) {
        defaultMessage.style.display = 'none';
      }
    };

    leftPaneListItems.forEach((listItem) => {
      const link = listItem.querySelector('a');
      if (!link) return;

      link.addEventListener('mouseenter', () => {
        const grandchildTargetId = listItem.dataset.grandchildTarget;
        const parentOnlyTargetId = listItem.dataset.parentOnlyTarget;
        const hasGrandchild = listItem.dataset.hasGrandchild === 'true';

        if (activeChildLink && activeChildLink !== link) {
          activeChildLink.classList.remove('active');
        }
        link.classList.add('active');
        activeChildLink = link;

        if (activeRightPanel) {
          activeRightPanel.style.display = 'none';
        }
        activeRightPanel = null;
        hideDefaultMessage();

        if (hasGrandchild) {
          const panel = rightPane.querySelector(`#${grandchildTargetId}`);
          if (panel) {
            panel.style.display = 'block';
            activeRightPanel = panel;
          } else {
            showDefaultMessage();
          }
        } else if (parentOnlyTargetId) {
          const panel = rightPane.querySelector(`#${parentOnlyTargetId}`);
          if (panel) {
            panel.style.display = 'block';
            activeRightPanel = panel;
          } else {
            showDefaultMessage();
          }
        } else {
          showDefaultMessage();
        }
      });
    });

    let initialTargetLink = null;
    if (leftPaneListItems.length > 0) {
        const firstWithGrandchildren = Array.from(leftPaneListItems).find(li => li.dataset.hasGrandchild === 'true');
        initialTargetLink = firstWithGrandchildren ? firstWithGrandchildren.querySelector('a') : leftPaneListItems[0].querySelector('a');
    }

    if (initialTargetLink) {
        initialTargetLink.dispatchEvent(new MouseEvent('mouseenter', { bubbles: true, cancelable: true }));
    } else if (leftPaneListItems.length === 0) { // No items in left pane at all
        showDefaultMessage();
    }


    // Mouseleave logic for the entire detailed-mega-menu container
    menuElement.addEventListener('mouseleave', (event) => {
      if (!menuElement.contains(event.relatedTarget)) {
        if (activeRightPanel) {
          activeRightPanel.style.display = 'none';
        }
        if (activeChildLink) {
          activeChildLink.classList.remove('active');
        }
        activeRightPanel = null;
        activeChildLink = null;
        // Decide if default message should show on mouseleave.
        // For now, let's assume we want to reset to the initial state, which might mean showing default if nothing auto-activates.
        // Or, if you want it to just hide everything and not show default:
        // hideDefaultMessage();
        // For consistency with initial load, let's re-trigger initial activation or show default.
        if (initialTargetLink) {
            initialTargetLink.dispatchEvent(new MouseEvent('mouseenter', { bubbles: true, cancelable: true }));
        } else if (leftPaneListItems.length === 0) {
            showDefaultMessage();
        } else {
            // If there are items, but none were specifically set as initial, and the first one doesn't have children
            const firstItemLink = leftPaneListItems[0] ? leftPaneListItems[0].querySelector('a') : null;
            if (firstItemLink && leftPaneListItems[0].dataset.hasGrandchild === 'false') {
                 firstItemLink.dispatchEvent(new MouseEvent('mouseenter', { bubbles: true, cancelable: true })); // This will show default message
            } else if (!firstItemLink) { // No items
                showDefaultMessage();
            }
        }
      }
    });
  };

  // Initialize only two-pane detailed mega menus (skip children-only layout)
  document.querySelectorAll('.detailed-mega-menu:not(.detailed-mega-menu--children-only)').forEach(setupDetailedMegaMenu);
});
</script> 