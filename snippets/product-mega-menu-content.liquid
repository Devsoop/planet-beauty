{% comment %}
  Renders the content for a standard product mega menu.
  Accepts:
  - current_link_object: The parent navigation link object.
  - layout_columns: The number of columns for the layout.
  - featured_block: The product block to feature, if any.
{% endcomment %}

<ul
  class="mega-menu__list page-width{% if current_link_object.levels == 1 %} mega-menu__list--condensed{% endif %} columns-{{ layout_columns }}"
  role="list"
>
  {%- for childlink in current_link_object.links -%}
    <li>
      <a
        id="HeaderMenu-{{ current_link_object.handle }}-{{ childlink.handle }}"
        href="{{ childlink.url }}"
        class="mega-menu__link mega-menu__link--level-2 link mega-menu__link mega-menu__link--parent{% if childlink.current %} mega-menu__link--active{% endif %}"
        {% if childlink.current %}
          aria-current="page"
        {% endif %}
      >
        {{ childlink.title | escape }}
      </a>
      {%- if childlink.links != blank -%}
        <ul class="list-unstyled" role="list">
          {%- for grandchildlink in childlink.links -%}
            <li>
              <a
                id="HeaderMenu-{{ current_link_object.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                href="{{ grandchildlink.url }}"
                class="mega-menu__link link{% if grandchildlink.current %} mega-menu__link--active{% endif %}"
                {% if grandchildlink.current %}
                  aria-current="page"
                {% endif %}
              >
                {{ grandchildlink.title | escape }}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </li>
  {%- endfor -%}

  {%- comment %}
    The original code looped through section.blocks again here.
    However, the parent snippet (header-mega-menu.liquid) already determines
    the specific `featured_block` that matches the `current_link_object`.
    So we can just render it directly if it exists.
  {% endcomment %}
  {%- if featured_block -%}
    {% render 'featured-mega-menu-items', block: featured_block %}
  {%- endif -%}
</ul> 