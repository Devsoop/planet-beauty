{%- comment -%} VERSION: 1.0.0 Please do not delete this line. {%- endcomment -%}
{%- capture bc_layout -%}
{%- case layout -%}
{%- when 'productGridItemHtml' -%}
{% raw %}
<div class="boost-pfs-filter-product-item boost-pfs-filter-product-item-grid {{gridWidthClass}}{{soldOutClass}}{{saleClass}} {{itemActiveSwapClass}}">
    <div class="boost-pfs-filter-product-item-inner">

        <div class="q htmlmmmmmmmmmmmm boost-pfs-filter-product-item-image">
            {{itemImages}}
            <div class="boost-pfs-filter-product-item-label">{{itemLabels}}{{itemTagLabels}}</div>
        </div>

        <div class="boost-pfs-filter-product-bottom">
          <div class="boost-pfs-filter-product-bottom-inner">
            {{itemVendor}}            
            <a href="{{itemUrl}}#" class="boost-pfs-filter-product-item-title">{{itemTitle}}</a>
            {{itemReviews}}
            {{itemPrice}}

<div>
<div class="eachSnip" id="category-snippet-1-{{itemId}}"></div>
  <a  style="display: block;" href="/cart/add?id={{itemVariantID}}&quantity=1" class="add-to-cart-link">Add to Cart</a>
</div>

 <script src="https://ui.powerreviews.com/stable/4.1/ui.js" async></script>

<script>
 window.pwr = window.pwr || function () {     
  (pwr.q = pwr.q || []).push(arguments); 
   
 };
 pwr("render", [{
 ENABLE_CLIENT_SIDE_STRUCTURED_DATA: true,
   api_key: '0ce9048c-1959-4821-8783-8bb2e0ac07ba',
   locale: 'en_US',
   merchant_group_id: '1720210388',
   merchant_id: '1424023529',
   page_id: {{itemId}},
   components: {
      CategorySnippet: 'category-snippet-1-{{itemId}}',
   
     }
   }
   ]);
  
</script>
 
            <style>
              .boost-pfs-filter-filter-dropdown li.created-descending,.boost-pfs-filter-filter-dropdown li.created-ascending{
                display:none !important; 
              }
                         .eachSnip {
            position: relative;
top: -8px;
}
              .pr-snippet {
    background: none;
    border: none;
    padding: 0;
}

.pr-snippet-stars {
    background: none;
    border: none;
    float: none;
    margin: auto;
    padding: 0;
    width: 110px;
}

.pr-snippet-review-count {
    display: none;
}

.pr-snippet-read-write {
    display: none;
}
              .pr-snippet-stars.pr-snippet-stars-png {
    width: 75px !important;
}
              .pr-category-snippet__total.pr-category-snippet__item {
    font-size: 9px !important;
padding-top: 4px;
padding-left: 0px;
}
              .pr-category-snippet__total pr-category-snippet__item {
  color: #dc0075 !important;
  outline: none !important;
  box-shadow: none !important;
}
              .pr-snippet.pr-category-snippet {
    margin: unset !important;
}
            
              .pr-snippet-rating-decimal {
    display: none !important;
}
              .pr-star-v4.pr-star-v4-100-filled {
    width: 12px !important;
    height: 12px !important;
}
              .pr-snippet-rating-decimal {
    display: none;
}
              .p-w-r .pr-snippet .pr-snippet-stars-png .pr-star, .p-w-r .pr-snippet .pr-snippet-stars-png .pr-star-accessible-0-filled, .p-w-r .pr-snippet .pr-snippet-stars-png .pr-star-accessible-100-filled, .p-w-r .pr-snippet .pr-snippet-stars-png .pr-star-accessible-25-filled, .p-w-r .pr-snippet .pr-snippet-stars-png .pr-star-accessible-50-filled, .p-w-r .pr-snippet .pr-snippet-stars-png .pr-star-accessible-75-filled, .p-w-r .pr-snippet .pr-snippet-stars-png .pr-star-half, .p-w-r .pr-snippet .pr-snippet-stars-png .pr-star-selected, .p-w-r .pr-snippet .pr-snippet-stars-png .pr-star-v4, .p-w-r .pr-snippet .pr-snippet-stars-png .pr-star-v4-0-filled, .p-w-r .pr-snippet .pr-snippet-stars-png .pr-star-v4-100-filled, .p-w-r .pr-snippet .pr-snippet-stars-png .pr-star-v4-25-filled, .p-w-r .pr-snippet .pr-snippet-stars-png .pr-star-v4-50-filled, .p-w-r .pr-snippet .pr-snippet-stars-png .pr-star-v4-75-filled {
    border-radius: 3px;
    height: 12px;
    margin-left: 0;
    margin-right: 2px;
    padding: 3px;
    width: 12px;
}

   .boost-pfs-filter-product-item-price {
  padding-bottom: 0px !important;
}        
             .add-to-cart-link {
                position: relative !important;
top: -8px !important;
               font-size: 12px !important;
              }
            </style>
            

           
            {{itemSwatches}}
          </div>
        </div>
    </div>
</div>
{% endraw %}
{%- when 'productListItemHtml' -%}
{% raw %}
<div class="boost-pfs-filter-product-item boost-pfs-filter-product-item-list {{soldOutClass}}{{saleClass}} {{itemActiveSwapClass}}">
  <div class="boost-pfs-filter-product-item-inner">
    <div class="boost-pfs-filter-product-item-image">
        {{itemImages}}
        <div class="boost-pfs-filter-product-item-label">{{itemLabels}}{{itemTagLabels}}</div>
    </div>
    <div class="boost-pfs-filter-product-bottom">
      <div class="boost-pfs-filter-product-bottom-inner">
        <a href="{{itemUrl}}" class="boost-pfs-filter-product-item-title">{{itemTitle}}</a>
        {{itemVendor}}
        {{itemReviews}}
        {{itemPrice}}
        <p class="boost-pfs-filter-des">{{itemDescription}}</p>
        {{itemSwatches}}
      </div>
    </div>
  </div>
</div>
{% endraw %}
{%- when 'productListPlaceholderHtml' -%}
{% raw %}
<div class="boost-pfs-filter-product-item boost-pfs-filter-product-item-list {{class.filterProductSkeleton}}">
  <div class="boost-pfs-filter-product-item-image">
    <div class="{{class.filterProductSkeleton}}-image" style="padding-top: {{paddingTop}}%"></div>
  </div>
  <div class="boost-pfs-filter-product-bottom">
    <div class="boost-pfs-filter-product-bottom-inner">
    <a href="#" class="boost-pfs-filter-product-item-title"><span class="boost-pfs-filter-skeleton-text boost-pfs-filter-skeleton-width4"></span></a>
    <p class="boost-pfs-filter-product-item-vendor"><span class="boost-pfs-filter-skeleton-text boost-pfs-filter-skeleton-width1"></span></p>
    <p class="boost-pfs-filter-product-item-price"><span class="boost-pfs-filter-skeleton-text boost-pfs-filter-skeleton-width2"></span></p>
    <p class="boost-pfs-filter-des">
      <span class="boost-pfs-filter-skeleton-text" style="width: 100%"></span><br />
      <span class="boost-pfs-filter-skeleton-text" style="width: 100%"></span><br />
      <span class="boost-pfs-filter-skeleton-text" style="width: 100%"></span><br />
      <span class="boost-pfs-filter-skeleton-text" style="width: 30%"></span>
    </p>
    </div>
  </div>
</div>
{% endraw %}

{%- when 'soldOutLabelHtml' -%}

<span class="soldout boost-pfs-filter-label boost-pfs-filter-label-display-{{- sold_out_display -}}">
{% if sold_out_display == 'image' %}
<img src="{{sold_out_img | img_url: 'medium'}}" alt="Sold out" />
{% else %}
{{ label_soldout | default: 'Sold Out' }}
{% endif %}
</span>

{%- when 'saleLabelHtml' -%}
<span class="sale boost-pfs-filter-label boost-pfs-filter-label-display-{{- sale_label_display -}}">
  {% if sale_label_display == 'image' %}
  <img src="{{sale_label_img | img_url: 'medium'}}" alt="Sale" />
  {% else %}
    {% if sale_label_display == 'sale_percent' %}
        {{label_sale_percent}}
    {% else %}
    {{- label_sale | default: 'Sale' -}}
    {% endif %}
  {% endif %}
</span>


{%- when 'tagLabelHtml' -%}
{% raw %}
<span class="tag boost-pfs-filter-label {{labelTag}}" >{{labelTag}}</span>
{% endraw %}

{%- when 'vendorHtml' -%}
{% raw %}
<p class="boost-pfs-filter-product-item-vendor">{{itemVendorLabel}}</p>
{% endraw %}

{%- when 'previousActiveHtml' -%}
