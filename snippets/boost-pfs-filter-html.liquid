{%- when 'pageItemHtml' -%}
{% raw %}
<li><a href="{{itemUrl}}" aria-label="Page {{itemTitle}}" title="Page {{itemTitle}}">{{itemTitle}}</a></li>
{% endraw %}

{%- when 'pageItemSelectedHtml' -%}
{% raw %}
<li><span class="boost-pfs-filter-pagination-active" aria-label="Page {{itemTitle}}">{{itemTitle}}</span></li>
{% endraw %}

{% when 'pageItemRemainHtml' %}
{% raw %}
<li><span aria-label="Page {{itemTitle}}">{{itemTitle}}</span></li>
{% endraw %}

{%- when 'paginateHtml' -%}
{% raw %}
<ul>{{previous}}{{pageItems}}{{next}}</ul>
{% endraw %}

{%- when 'sortingHtml' -%}

<button class="boost-pfs-filter-top-sorting-wrapper" aria-label="{%- assign temp = 'collections.sorting.title' | t  -%} {%- unless temp contains 'translation missing'  -%} {{- temp -}} {%- else -%} Sorting {%- endunless -%}"><span aria-hidden="true"><span aria-hidden="true" class='11'> {%- assign temp = 'collections.sorting.title' | t  -%} {%- unless temp contains 'translation missing'  -%} {{- temp -}} {%- else -%} Sorting {%- endunless -%}</span></span></button>
{% raw %}
<ul class="q boost-pfs-filter-filter-dropdown">{{sortingItems}}</ul>
{% endraw %}

{%- when 'showLimitHtml' -%}
{% raw %}
<label> Show </label><select class="w boost-pfs-filter-filter-dropdown">{{showLimitItems}}</select>
{% endraw %}

{%- when 'breadcrumbHtml' -%}
{% raw %}
<a href="/"> Home </a> {{breadcrumbDivider}} {{breadcrumbItems}}
{% endraw %}

{%- when 'breadcrumbDivider' -%}
<span class="divider">/</span>

{%- when 'breadcrumbItemLink' -%}
{% raw %}
<a href="{{itemLink}}">{{itemTitle}}</a>
{% endraw %}

{%- when 'breadcrumbItemSelected' -%}
{% raw %}
<span>{{itemTitle}}</span>
{% endraw %}

{%- endcase -%}
{%- endcapture -%}

