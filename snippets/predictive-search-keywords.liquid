{%- doc -%}
  Renders clickable keywords for predictive search
  
  @param {string[]} keywords - Array of keyword strings to display
  @param {string} [class] - Additional classes to add to the keywords container
  
  @example
  {% render 'predictive-search-keywords', keywords: 'shirts,shoes,accessories' | split: ',' %}
{%- enddoc -%}

{%- if keywords.size > 0 -%}
  <div class="predictive-search-keywords{% if class != blank %} {{ class | strip }}{% endif %}" data-predictive-search-keywords>
    <h2 class="predictive-search-keywords__title">Popular Keywords</h2>
    <div class="predictive-search-keywords__list">
      {%- for keyword in keywords -%}
        {%- assign keyword_text = keyword | strip -%}
        {%- if keyword_text != blank -%}
          <button
            type="button"
            class="predictive-search-keyword"
            data-keyword="{{ keyword_text | escape }}"
            aria-label="Search for {{ keyword_text }}"
          >
            {{ keyword_text }}
          </button>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .predictive-search-keywords {
    padding-block: var(--padding-md, 16px);
    padding-inline: var(--padding-xl, 20px);
    margin-block-end: var(--margin-md, 16px);
  }

  .predictive-search-keywords__title {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--font-size--body-md);
    font-weight: 500;
    margin-block: var(--margin-sm) var(--margin-xs);
    width: 100%;
    text-transform: var(--title-case);
    color: var(--color-foreground);

    &:first-of-type {
      margin-block-start: 0;
    }

    @media screen and (max-width: 749px) {
      margin-block: var(--margin-lg) var(--margin-sm);
    }
  }

  .predictive-search-keywords__list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap-xs, 8px);
  }

  .predictive-search-keyword {
    padding: var(--padding-xs, 8px) var(--padding-sm, 12px);
    border: var(--border-width-sm, 1px) solid var(--color-border);
    border-radius: var(--style-border-radius-inputs, 4px);
    background-color: var(--color-background);
    color: var(--color-foreground);
    font-size: var(--font-size--body-sm, 14px);
    cursor: pointer;
    transition: background-color var(--animation-speed-medium) var(--animation-timing-hover),
      border-color var(--animation-speed-medium) var(--animation-timing-hover),
      transform var(--animation-speed-medium) var(--animation-timing-bounce);
    white-space: nowrap;
  }

  .predictive-search-keyword:hover {
    background-color: rgb(var(--color-foreground-rgb) / var(--opacity-8));
    border-color: var(--color-border);
    transform: scale(1.02);
  }

  .predictive-search-keyword:active {
    transform: scale(0.98);
    transition: transform 100ms var(--animation-timing-active);
  }

  .predictive-search-keyword:focus-visible {
    outline: var(--focus-outline-width) solid var(--color-primary);
    outline-offset: var(--focus-outline-offset);
  }
{% endstylesheet %}


