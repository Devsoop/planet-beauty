{% assign current_variant = product.selected_or_first_available_variant %}
{% assign product_price = current_variant.price %}
{% assign product_compare_price = current_variant.compare_at_price %}
<style>
  .loading_tr img{
    opacity:1;
    position: absolute;
    top: 0;
    width: 100%;
    height: 100%;
  }
  .product-card__image-container{
    display:block !important;
  }
  .tapcart_cart_btn{
    padding: 10px 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2px;
    margin: 0 auto;
    background:#000;
    border-radius:8px;
  }
  ..product-card__name{
    height:20px;
  }
  .tapcart_cart_btn .tc_btn_plus{
        font-size: 25px;
    line-height: 13px;
  }
  .tapcart_cart_btn .tc_btn_text{
        text-transform: none;
  }
  @media screen and (max-width: 767px) {
  .carousel__products{
    padding-top:162%;
  }
    .tr_img_mob{
      max-width:60%;
      margin:0 auto;
    }
  }
</style>
<div class="product-card" data-product-card="{{product.handle}}" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
    <div class="product-card__wrapper">
        <!-- <a class="product-card__link" href="{{product.url}}" itemprop="item">
            <span class="visually-hidden">{{ product.title }}</span>
        </a> -->
        <div class="product-card__image-container">

            {%- assign preview_image = product.featured_media.preview_image -%}

            {%- assign aspect_ratio = 1 -%}
            
            <div class="product-card__image-wrapper">
                {% if preview_image != blank %}
                    {%- assign img_url = preview_image | img_url: '400x' -%}
                    <img class="tr_img_mob" loading="eager" src="{{img_url}}" alt="{{img_url.alt}}"/>
                {% else %}
                    <div style="position: absolute;top: 0;width: 100%;height: 100%;">
                        {% render 'product-placeholder' %}
                    </div>
                {% endif %}
            </div>

            <div class="product-card__labels">

                {% assign all_variants_out_of_stock = true %}
                {% for variant in product.variants %}
                    {% if variant.available %}
                        {% assign all_variants_out_of_stock = false %}
                        {% break %}
                    {% endif %}
                {% endfor %}
            
                {% if all_variants_out_of_stock %}
                    <div class="product-card__label">sold out</div>
                {% endif %}
            
                {% for tag in product.tags %}
                    {% if tag == 'label:new' %}
                        <div class="product-card__label product-card__label--new">new</div>
                    {% elsif tag == 'label:sale' %}
                        <div class="product-card__label">sale</div>
                    {% endif %}
                {% endfor %}
            
            </div>

            <div class="product-card__swatches" data-variant-content></div>

            {% comment %}  
            <div class="product-card__swatches">
                <img class="product-card__swatch-image" src="https://via.placeholder.com/40x40" alt="option 1">
                <img class="product-card__swatch-image" src="https://via.placeholder.com/40x40" alt="option 2">
                <img class="product-card__swatch-image" src="https://via.placeholder.com/40x40" alt="option 3">
                <img class="product-card__swatch-image" src="https://via.placeholder.com/40x40" alt="option 4">
                <span class="product-card__swatches-qty">+22</span>
            </div>{% endcomment %}
            {% comment %} <div class="product-card__swatches product-card__swatches--ounce ">
                <div class="product-card__swatch-ounce product-card__swatch-ounce--selected">10oz</div>
                <div class="product-card__swatch-ounce">32oz</div>
            </div> {% endcomment %}
            
        </div>
        <div class="product-card__text-container" style="text-align:left;">
            <div class="product-card__name" itemprop="name">{{ product.title | truncate: 30 }}</div>
            <meta itemprop="position" content="{{forloop.index}}" />
            <div class="product-card__price-container">

                    <div class="product-card__sale-price"> {{ line_item.original_price | money }}</div>

            </div>
          
        </div>
        <input type="number" id="quantity" name="quantity" value="1" min="1" style="display:none;">
        <input type="hidden" name="id" value="{{ line_item.variant_id }}" id="{{ product.id }}select">
          <div class="rebuy-product-actions">
            <button data-product-id="{{ product.id }}select" aria-label="Add the product, {{ product.title }}" type="button" class="tapcart_cart_btn"><span class="tc_btn_plus">+</span><span class="tc_btn_text">Cart</span></button>
          </div>
        {% if show_product_reviews %}
            {% render 'power-reviews-category-review', product: product %}
        {% endif %}

    </div>
</div>