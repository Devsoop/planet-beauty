    					<div class="hot-deals-wrap">
                          <h2>Hot Deals For You</h2>
      					<ul>
      						{% for product in collections['all'].products limit:6 %}
                                <li>
                                    <div class="img-wrap">  <img src="{{ product.featured_image | product_img_url: 'medium' }}" alt="{{ product.title }}"></div>
                                    <div class="content">
                                        <h3>{{product.title | strip_html | truncate: 25}}</h3>
                                        <p class="pera">{{product.description | strip_html | truncate: 90 }}</p>
                                        <h6 class="pr">{{ product.price | money | remove: ' ' | remove: '.00' }}</h6>
                                        <a href="{{ product.url }}">View Item <i class="fas fa-arrow-right"></i></a>
                                    </div>
                                </li>
                                {% endfor %}
      						
      					</ul>
                      </div>
                       
    					<div class="deals-wrap">
                          <a href="{{ shop.url }}/collections/sale" class="down">
                              View All Deals
                          </a>
                      </div>
                    </div>
  				</div>
                
  			</div>
  		</div>
  	</section>
  	<section class="hot-deals halfsec">
    <div class="c-container">
      <div class="c-row">
        <h2>People Have Also Been Looking at These Products</h2>
        {% for product in collections['all'].products limit:4 %}
        <div class="c-col-3">
          <ul>
            <li>
              <div class="img-wrap">  <img src="{{ product.featured_image | product_img_url: 'medium' }}" alt="{{ product.title }}"></div>
              <div class="content">
                <h3>{{product.title | strip_html | truncate: 28}}</h3>
                <p class="pera">{{product.description | strip_html | truncate: 30 }}</p>
                <h6>{{ product.price | money | remove: ' ' | remove: '.00' }}</h6>
                <a href="{{ product.url }}">View Item <i class="fas fa-arrow-right"></i></a>
              </div>
            </li>
          </ul>
        </div>
  
        {% endfor %}
  
      </div>
    </div>
  </section>
