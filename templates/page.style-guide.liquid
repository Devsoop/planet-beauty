                                text_color: "#FFFFFF",
                                small_style: true,
                                mobile_image: 'http://via.placeholder.com/600x700/',
                                mobile_aspect_ratio: aspect_ratio_mobile,
                                tablet_image: 'http://via.placeholder.com/1200x500/',
                                tablet_aspect_ratio: aspect_ratio_tablet,
                                desktop_image: 'http://via.placeholder.com/1300x280/',
                                desktop_aspect_ratio: aspect_ratio_desktop %}
