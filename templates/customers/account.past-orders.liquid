<!-- /templates/customers/account.liquid -->
<style>
  div[data-rebuy-id="82694"] {
    display: none !important;
}
  #mob_customer_orders{
    display:none;
  }
  .mob_order_detail{
    display:flex;
    align-items:center;
    text-align: left;
    margin-bottom: 20px;
  }
  .mob_order_detail span, .mob_order_detail a{
    display:block;
    text-decoration:none;
  }
  .mob_order_detail *{
    padding:0;
    margin:0;
    font-weight:bold;
    width:calc(100%/2);
  }
  .mob_orders_wrapper{
    border-bottom: 1px solid #000;
    margin-bottom: 20px;
  }
  .reorder_btn{
    border: 1px solid #000;
    padding: 3px;
    width: 100px;
    text-align: center;
    border-radius: 5px;
  }
  .ord_time{
    width: 130px;
    font-size: 12px;
  }
  @media screen and (max-width: 767.98px) {
    #customer_orders{
    display:none;
  }
    #mob_customer_orders{
    display:block;
  }
  }
  </style>
<div class="page-container">

    <div class="container">

        <div class="page-width account-template">
            <div class="account-template__header new_section">
                <h1 class="account-template__title">
                  Welcome 
                  {% if customer.default_address %}                          
                       {{ customer.default_address.first_name }}
                          {% else %}
                          {{customer.first_name}}
                        {% endif %}
                  
                  
                  </h1>
            </div>

            <div id="customer_orders" class="account-template__orders">
                <h2>Orders</h2>
                {% paginate customer.orders by 10 %}
                {% if customer.orders.size != 0 %}
                <!-- order details here -->
                <table class="account-template__table-orders">
                    <thead>
                        <tr>
                            <th scope="col">{{ 'customer.orders.order_number' | t }}</th>
                            <th scope="col">{{ 'customer.orders.date' | t }}</th>
                            <th scope="col">Tracking number</th>
                            <th scope="col">{{ 'customer.orders.fulfillment_status' | t }}</th>
                            <th scope="col">{{ 'customer.orders.total' | t }}</th>
                          <th scope="col">Re-Order</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for order in customer.orders %}
                        <tr>
                            <th data-label="{{ 'customer.orders.order_number' | t }}" scope="row">
                                <a href="{{ order.customer_url }}" class="" aria-label="{{ 'customer.orders.order_number_link' | t: number: order.name }}">{{ order.name }} </a>
                            </th>
                            <td data-label="{{ 'customer.orders.date' | t }}">{{ order.created_at | time_tag: format: 'date' }} <span>
                         
{% comment %}
{% assign _cart = "/cart/" %}
  {% assign reorder_url = "" %}

  {% for line_item in order.line_items %}
    {%- capture reorder_url -%}
      {{ reorder_url | append: _cart | append: line_item.variant_id | append: ':' | append: line_item.quantity | append: ',' | strip }}
    {%- endcapture -%}
  {% endfor %}

  <a href="{{ reorder_url | strip }}" class="button tiny">Re--order</a>

{% endcomment %}
  





                              
                            
                            </span>
                            
                            </td>
                           
                          
                          <td data-label="{{ 'customer.orders.payment_status' | t }}">
                           {% comment %} {{ order.financial_status_label }}  {% endcomment %} 
                            {% for line_item in order.line_items %}
     {% if forloop.first == true %}
<a href="{{ line_item.fulfillment.tracking_url }}" target="_blank">{{ line_item.fulfillment.tracking_number }}</a>

     {% endif %}
{% endfor %} 
                            
                          
                          </td>
                           
                          
                          <td data-label="{{ 'customer.orders.fulfillment_status' | t }}">{{ order.fulfillment_status_label }}</td>
                            <td data-label="{{ 'customer.orders.total' | t }}">{{ order.total_price | money }}</td>
                          <td data-label="Reorder"><a target="_blank" href="https://www.planetbeauty.com/apps/rebuy/reorder?shopify_order_id={{ order.id }}">Reorder</a></td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
                {% else %}
                <p>You haven't placed any orders yet.</p>
                {% endif %}
                {{ paginate | default_pagination }}
                {% endpaginate %}
            </div>
<div id="mob_customer_orders">
  {% paginate customer.orders by 10 %}
                {% if customer.orders.size != 0 %}
                  <h3>Your Orders</h3>
                  {% for order in customer.orders %}

  <div class="mob_orders_wrapper">
  <div class="mob_order_detail mob_order_p1">
    <div>
      <span class="ord_time">{{ order.created_at | time_tag: format: 'date' }}</span>
      <h3>{{ order.name }}</h3>
    </div>
    
    <p>Tracking number: {% if line_item.fulfillment.tracking_number != blank %}<a href="{{ line_item.fulfillment.tracking_url }}" target="_blank">{{ line_item.fulfillment.tracking_number }}</a>{% else %}<span>{{ order.fulfillment_status_label }}</span>{% endif %}</p>
  </div>
  <div class="mob_order_detail mob_order_p2">
    
    <p><a class="reorder_btn" target="_blank" href="https://www.planetbeauty.com/apps/rebuy/reorder?shopify_order_id={{ order.id }}">BUY AGAIN</a></p>
    <p>Total {{ order.total_price | money }}</p>
  </div>
        </div>

                    {% endfor %}
  {% endif %}
                {{ paginate | default_pagination }}
                {% endpaginate %}
</div>
</div>

<style>
@media screen and (max-width: 768px){
 .left {   
    width: 100%;
   padding-left: 0px;
}
  .right {
    padding-left: 0px !important;
    width: 100%;
}
}
  
</style>

