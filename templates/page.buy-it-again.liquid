<style>
                    #shopify-section-alert-message, #shopify-section-header, #shopify-section-footer, #onetrust-consent-sdk{
                      display:none;
                    }
  </style>
{% if customer %}
<div class="page-container static-page" data-static-page >

  <div class="container">

{% paginate customer.orders by 30 %}
                {% if customer.orders.size != 0 %}
                  <style>
                    .rebuy-button {
    display: block;
    margin: 0;
    outline: none;
    border-width: 2px;
    border-style: solid;
    border-radius: 5px;
    border-color: #2491c4;
    box-shadow: none;
    background: #2491c4;
    padding: 10px 15px;
    width: 100%;
    height: auto;
    text-align: center;
    color: #fff;
    font-size: 16px
}
                    .tr_tapcart_wrapper{
                      display:flex;
                      flex-wrap:wrap;
                          align-items: flex-end;
    justify-content: center;
                    }
                    .product-card__image-wrapper{
                      text-align:center;
                    }
                    .tr_tapcart_product{
                      width:calc(100%/2);
                      margin-bottom:40px;
                    }
                    .rebuy-button{
                      margin-top: 10px;
    color: #fff;
    background: #dc0075;
    border-color: #dc0075;
                    }
  @media (min-width: 1200px) {
    .carousel__products {
         padding-top: 50%;
    }
}
</style>
<div class="section-products-carousel">    
      <div class="carousel__heading-wrapper">
          <h2 class="carousel__heading h1 highlight">But It Again</h2>
      </div>

      <div class="carousel__products">
          <div class="carousel__products-container">
          <div class="tr_tapcart_wrapper">
            {% assign product_ids = "" %}
            {% for order in customer.orders limit:30 %}  
            {% for line_item in order.line_items %}
              {% unless product_ids contains line_item.product.id %}
              {% assign lil_tit = line_item.title | handle %}
              {% if lil_tit contains 'free' or lil_tit contains 'shipping' %}
                {% else %}
              {% if line_item.product.available%}
                  <div class="tr_tapcart_product">{% render 'product-card-new', product: line_item.product, line_item: line_item %}</div>
                {% else %}

                {% endif %}
                {% endif %}
                              {% assign product_ids = product_ids | append: line_item.product.id | append: "," %}
              {% endunless %}
              {% endfor %}
            {% endfor %}

          </div>
        </div>
      </div>
</div>
                              {% endif %}
    {% endpaginate %}
  </div>
