  </script> -->
</div>
{% else %}
<!-- /templates/customers/login.liquid -->

<div class="page-width login-form-template">
    <div class="login-form-container active" data-customer-login-form>
        <div class="heading__wrapper"> 
            <h1 class="heading h1 highlight-internal">{{ 'customer.login.title' | t }}</h1>
        </div>
        <div class="login-form__message-success login-form__recover-password-success" data-reset-password-success-msg>
            {{ 'customer.recover_password.success' | t }}
        </div>
        {% form 'customer_login' %}
          <input type="hidden" name="return_to" value="/pages/buy-it-again">
            {%- if form.errors -%}
                <div class="login-form__message--error">
                    <h2>{{ 'contact.form.error_heading' | t }}</h2>
                    {{ form.errors | default_errors }}
                </div>
            {%- endif -%}

            <label for="customer_email">{{ 'customer.login.email' | t }}
                <input id="customer_email" type="email" name="customer[email]" />
            </label>

            {% if form.password_needed %}
                <label for="customer_password" data-password-input>{{ 'customer.login.password' | t }}
                    <input id="customer_password" type="password" name="customer[password]" />
                    <button type="button" class="btn-link" aria-label="Show password" data-password-show>{% include "icon-hide" %}</button>
                    <button type="button" class="btn-link" aria-label="Hide password" data-password-hide>{% include "icon-show" %}</button>
                </label>
            {% endif %}

            <div>


                <input type="submit" class="btn buy_it_again_login" value="{{ 'customer.login.sign_in' | t }}">

            </div>
        {% endform %}

        <!-- Begin ReCharge code -->
            {% render 'subscription-account-login' %}
        <!-- End ReCharge code -->

    </div>

    <div class="login-form-container login-form__recover-password" data-recover-password-form>
        <h2 class="login-form__title-recover-password">{{ 'customer.recover_password.title' | t }}</h2>

        {% form 'recover_customer_password' %}
            {% if form.posted_successfully? %}
                <span data-recover-password-form-success></span>
            {% endif %}

            {%- if form.errors -%}
                <div class="login-form__message--error">
                    {{ form.errors | default_errors }}
                </div>
            {%- endif -%}

            <label for="recover_customer_email">{{ 'customer.login.email' | t }}</label>
            <input type="email" name="email" id="recover_customer_email"/>

            <input type="submit" class="btn" value="Submit" />
            
            <a class="btn btn-full" href="{{ routes.account_login_url }}" class="btn">{{ 'customer.recover_password.cancel' | t }}</a>
       
        {% endform %}
    </div>
</div>
  <script>

        document.querySelector('.buy_it_again_login').addEventListener('click', function() {

                this.value = 'logging...';
        });
    </script>
  {% endif %}
