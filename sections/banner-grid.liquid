<div class="banner-grid">
    <div class="image-grid">
        {% for block in section.blocks %}
            {% if block.settings.desktop_image != blank %}
                <div class="image-grid__item"><a {% if block.settings.link != blank %} href="{{block.settings.link}}" {% endif %}>
                    
                    {%- assign desktop_image = block.settings.desktop_image | img_url: '1000x' -%}
                    {%- assign tablet_image = block.settings.tablet_image | img_url: '700x' -%}
                    {%- assign mobile_image = block.settings.mobile_image | img_url: '500x' -%}
                    {%- assign heading = block.settings.heading | escape -%}

                    {% render 'banner-overlay', 
                    heading:  heading ,
                    subheading: block.settings.subheading,

                    mobile_image: mobile_image, 
                    mobile_aspect_ratio: block.settings.mobile_image.aspect_ratio,
                    mobile_image_width: block.settings.mobile_image.width, 
                    mobile_image_height: block.settings.mobile_image.height, 

                    tablet_image:  tablet_image, 
                    tablet_aspect_ratio:  block.settings.tablet_image.aspect_ratio, 
                    tablet_image_width: block.settings.tablet_image.width, 
                    tablet_image_height: block.settings.tablet_image.height, 

                    desktop_image:  desktop_image, 
                    desktop_aspect_ratio:  block.settings.desktop_image.aspect_ratio,
                    desktop_image_width: block.settings.desktop_image.width, 
                    desktop_image_height: block.settings.desktop_image.height, 

                    overlay_position: block.settings.overlay_position ,
                    text_align: block.settings.text_align ,
                    text_color:  block.settings.text_color ,
                    small_style: block.settings.small_style  %}

                </a></div>
            {% endif %}
        {% endfor %}
    </div>
</div>

{% schema %}
{
  "name": "Banner Grid",
  "settings": [],
  "blocks": [
    {
        "type": "banner",
        "name": {
        "en": "Banner"
        },
        "settings": [
            {
                "type": "header",
                "content": "Text"
            },
            {
                "type": "text",
                "id": "heading",
                "label": "Heading"
            },
            {
                "type": "text",
                "id": "subheading",
                "label": "Subheading"
            },
            {
                "type": "color",
                "id": "text_color",
                "label": "Text color",
                "default": "#ffffff"
             },
            {
                "type": "header",
                "content": "Image"
            },
            {
                "type": "image_picker",
                "id": "mobile_image",
                "label": {
                "en": "Mobile Image"
                }
            },
            {
                "type": "image_picker",
                "id": "tablet_image",
                "label": {
                "en": "Tablet Image"
                }
            },
            {
                "type": "image_picker",
                "id": "desktop_image",
                "label": {
                "en": "Desktop Image"
                }
            },
            {
              "id": "link",
              "type": "url",
              "label": "Link"
            },
            {
                "type": "header",
                "content": "Position and Size"
            },
            {
                "type": "select",
                "id": "overlay_position",
                "options": [
                   { "value": "top", "label": "Top"},
                   { "value": "middle", "label": "Middle"},
                   { "value": "bottom", "label": "Bottom"}
                ],
                "label": "Overlay Position"
             },
             {
                "type": "select",
                "id": "text_align",
                "options": [
                   { "value": "left", "label": "Left"},
                   { "value": "right", "label": "Right"},
                   { "value": "center", "label": "Center"}
                ],
                "label": "Text Align"
             },
             {
                "type": "checkbox",
                "id": "small_style",
                "default": true,
                "label": "Small Style"
             }
        ]
    }
  ],
  "presets": [
    {
      "name": {
        "en": "Banner Grid"
      },
      "category": {
        "en": "Image"
      },
      "blocks": [
        {
          "type": "banner"
        },
        {
          "type": "banner"
        }
      ]
    }
  ]
}
{% endschema %}