<div class="accordion" role="navigation" data-accordion>
    {%- for block in section.blocks -%}
        <div class="accordion__item">
            <button class="accordion__heading" id="btnFaq{{ forloop.index }}" aria-expanded="false" aria-controls="contentFaq{{ forloop.index }}" data-accordion-heading>{{block.settings.heading}}{% render 'icon-chevron' %}</button>
            <div class="accordion__content" id="contentFaq{{ forloop.index }}" role="region" aria-labelledby="btnFaq{{ forloop.index }}" data-accordion-content>

                {{block.settings.content}}

            </div>
        </div>
    {% endfor %}
</div>
  
{% schema %}
  {
      "blocks": [
          {
              "name": "Item",
              "type": "faq_item",
              "settings": [
                  {
                      "type": "text",
                      "label": "Title",
                      "id": "heading",
                      "default": "Heading"
                  },
                  {
                      "type": "html",
                      "label": "Content",
                      "id": "content",
                      "default": "<p>FAQ description goes here</p>"
                  }
              ]
          }
      ]
  }
{% endschema %}
  