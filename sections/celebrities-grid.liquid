{% if section.settings.enable_celebrities_grid %}

  <div class="celebrities-grid">
      
    {% for block in section.blocks %}

      {% if block.settings.desktop_image != blank %}

        {%- assign desktop_image = block.settings.desktop_image | img_url: '1300x' -%}
        {%- assign tablet_image = block.settings.tablet_image | img_url: '1200x' -%}
        {%- assign mobile_image = block.settings.mobile_image | img_url: '600x' -%}
        {%- assign name = block.settings.celebrity_name | escape -%}

        <div class="image-grid__item {% if block.settings.full_image %}image-grid__item--full{% endif %}">
          {% render 'banner-overlay',
            heading:  name , 
            small_style: true,
            mobile_image: mobile_image,
            mobile_aspect_ratio: block.settings.mobile_image.aspect_ratio,
            tablet_image: tablet_image,
            tablet_aspect_ratio: block.settings.tablet_image.aspect_ratio,
            desktop_image: desktop_image,
            desktop_aspect_ratio: block.settings.desktop_image.aspect_ratio,
            overlay_position: block.settings.overlay_position ,
            text_align: block.settings.text_align ,
            text_color:  block.settings.text_color , %}
        </div>

      {% endif %}

    {% endfor %}
      
  </div>

{% endif %}

{% schema %}
  {
    "name": "Celebrities Grid",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_celebrities_grid",
        "default": true,
        "label": "Enable this section"
      }
      ],
      "blocks": [
      {
        "type": "celebrity",
        "name": "Celebrity",
        "settings": [
          {
            "type": "text",
            "id": "celebrity_name",
            "label": "Name"
          },
          {
            "type": "color",
            "id": "text_color",
            "label": "Text color",
            "default": "#ffffff"
          },
          {
            "type": "header",
            "content": "Images"
          },
          {
            "type": "image_picker",
            "id": "mobile_image",
            "label": "Mobile Image"
          },
          {
            "type": "image_picker",
            "id": "tablet_image",
            "label": "Tablet Image"
          },
          {
            "type": "image_picker",
            "id": "desktop_image",
            "label": "Desktop Image"
          },
          {
            "type": "header",
            "content": "Full width"
          },
          {
            "type": "select",
            "id": "overlay_position",
            "options": [
               { "value": "top", "label": "Top"},
               { "value": "middle", "label": "Middle"},
               { "value": "bottom", "label": "Bottom"}
            ],
            "label": "Overlay Position"
          },
          {
            "type": "select",
            "id": "text_align",
            "options": [
              { "value": "left", "label": "Left"},
              { "value": "right", "label": "Right"},
              { "value": "center", "label": "Center"}
            ],
            "label": "Text Align"
          },
          {
            "type": "checkbox",
            "id": "full_image",
            "default": false,
            "label": "Full Image"
          }
        ]
      }
    ]
  }
{% endschema %}