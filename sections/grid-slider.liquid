
{%- liquid
  assign slider_any = false
  if section.settings.slider_desktop or section.settings.slider_tablet or section.settings.slider_mobile
    assign slider_any = true
  endif

  if section.settings.section_width == 'page-width'
    assign gutter_width = 'var(--util-page-margin-offset)'
  else
    assign gutter_width = '0px'
  endif
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    section-grid-slider
    spacing-style
    gap-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: 12 %}
  "
  data-testid="grid-slider-section"
>
  {% content_for 'block', type: 'group', id: 'static-header' %}

  <grid-slider-component
    {% if section.settings.slider_desktop %}desktop-slider{% endif %}
    {% if section.settings.slider_tablet %}tablet-slider{% endif %}
    {% if section.settings.slider_mobile %}mobile-slider{% endif %}
    {% if section.settings.section_width == 'page-width' %}has-gutters{% endif %}
    class="grid-slider"
    style="
      --gs-gutter-width: {{ gutter_width }};
      --gs-columns-desktop: {{ section.settings.columns_desktop }};
      --gs-columns-tablet: {{ section.settings.columns_tablet }};
      --gs-columns-mobile: {{ section.settings.columns_mobile }};
      --gs-peek-desktop: {{ section.settings.peek_desktop }};
      --gs-peek-tablet: {{ section.settings.peek_tablet }};
      --gs-peek-mobile: {{ section.settings.peek_mobile }};
      --gs-gap-desktop: {{ section.settings.gap_desktop }}px;
      --gs-gap-tablet: {{ section.settings.gap_tablet }}px;
      --gs-gap-mobile: {{ section.settings.gap_mobile }}px;
    "
  >
    <div class="grid-slider__inner" data-gs-ref="inner">
      <div class="grid-slider__track" data-gs-ref="track">
        {% content_for 'blocks' %}
      </div>
    </div>

    {%- if slider_any and section.settings.icons_style != 'none' -%}
      <div class="grid-slider__arrows" data-gs-ref="arrows">
        <button
          class="
            grid-slider__btn grid-slider__btn--prev
            slideshow-control slideshow-control--previous
            {% if section.settings.icons_shape != 'none' %}slideshow-control--shape-{{ section.settings.icons_shape }}{% endif %}
            slideshow-control--style-{{ section.settings.icons_style }}
            button button-unstyled button-unstyled--transparent flip-x
          "
          data-gs-ref="prevBtn"
          aria-label="{{ 'accessibility.slideshow_previous' | t }}"
          disabled
        >
          <span class="svg-wrapper icon-{% if section.settings.icons_style contains 'chevron' %}caret{% else %}arrow{% endif %}">
            {%- if section.settings.icons_style contains 'chevron' -%}
              {{- 'icon-caret.svg' | inline_asset_content -}}
            {%- else -%}
              {{- 'icon-arrow.svg' | inline_asset_content -}}
            {%- endif -%}
          </span>
        </button>
        <button
          class="
            grid-slider__btn grid-slider__btn--next
            slideshow-control slideshow-control--next
            {% if section.settings.icons_shape != 'none' %}slideshow-control--shape-{{ section.settings.icons_shape }}{% endif %}
            slideshow-control--style-{{ section.settings.icons_style }}
            button button-unstyled button-unstyled--transparent
          "
          data-gs-ref="nextBtn"
          aria-label="{{ 'accessibility.slideshow_next' | t }}"
        >
          <span class="svg-wrapper icon-{% if section.settings.icons_style contains 'chevron' %}caret{% else %}arrow{% endif %}">
            {%- if section.settings.icons_style contains 'chevron' -%}
              {{- 'icon-caret.svg' | inline_asset_content -}}
            {%- else -%}
              {{- 'icon-arrow.svg' | inline_asset_content -}}
            {%- endif -%}
          </span>
        </button>
      </div>
    {%- endif -%}
  </grid-slider-component>
</div>

<script src="{{ 'grid-slider.js' | asset_url }}" defer></script>

{% stylesheet %}
  /* ─── Component base ─── */
  grid-slider-component {
    display: block;
  }

  .grid-slider__inner {
    width: 100%;
  }

  /* ─── Default: CSS Grid layout ─── */
  .grid-slider__track {
    display: grid;
    grid-template-columns: repeat(var(--gs-columns-mobile, 1), 1fr);
    gap: var(--gs-gap-mobile, 12px);
  }

  @media (min-width: 750px) {
    .grid-slider__track {
      grid-template-columns: repeat(var(--gs-columns-tablet, 3), 1fr);
      gap: var(--gs-gap-tablet, 16px);
    }
  }

  @media (min-width: 1200px) {
    .grid-slider__track {
      grid-template-columns: repeat(var(--gs-columns-desktop, 4), 1fr);
      gap: var(--gs-gap-desktop, 16px);
    }
  }

  /* ─── Slider mode: base styles (class toggled by JS) ─── */
  .grid-slider__track--slider {
    display: flex;
    flex-direction: row;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .grid-slider__track--slider::-webkit-scrollbar {
    display: none;
  }

  .grid-slider__track--slider > * {
    flex: 0 0 auto;
    scroll-snap-align: start;
  }

  /* ─── Slider card widths per breakpoint ─── */
  /*
    Formula: card_width = (track_width - gap × (cols − 1)) / (cols + peek)
    peek = 0 → no peek; peek = 0.5 → half of next card visible (1.5 total)
  */

  @media (max-width: 749px) {
    .grid-slider[mobile-slider] .grid-slider__track--slider {
      gap: var(--gs-gap-mobile, 12px);
    }

    .grid-slider[mobile-slider] .grid-slider__track--slider > * {
      width: calc(
        (100% - var(--gs-gap-mobile, 12px) * (var(--gs-columns-mobile, 1) - 1)) /
        (var(--gs-columns-mobile, 1) + var(--gs-peek-mobile, 0))
      );
      max-width: none;
    }
  }

  @media (min-width: 750px) and (max-width: 1199px) {
    .grid-slider[tablet-slider] .grid-slider__track--slider {
      gap: var(--gs-gap-tablet, 16px);
    }

    .grid-slider[tablet-slider] .grid-slider__track--slider > * {
      width: calc(
        (100% - var(--gs-gap-tablet, 16px) * (var(--gs-columns-tablet, 3) - 1)) /
        (var(--gs-columns-tablet, 3) + var(--gs-peek-tablet, 0))
      );
      max-width: none;
    }
  }

  @media (min-width: 1200px) {
    .grid-slider[desktop-slider] .grid-slider__track--slider {
      gap: var(--gs-gap-desktop, 16px);
    }

    .grid-slider[desktop-slider] .grid-slider__track--slider > * {
      width: calc(
        (100% - var(--gs-gap-desktop, 16px) * (var(--gs-columns-desktop, 4) - 1)) /
        (var(--gs-columns-desktop, 4) + var(--gs-peek-desktop, 0))
      );
      max-width: none;
    }
  }

  /* ─── Full-bleed: extend slider to viewport edges on page-width sections ─── */
  .grid-slider__inner--full-bleed {
    width: 100vw;
    margin-inline-start: calc(-1 * var(--gs-gutter-width, 0px));
    overflow: hidden;
  }

  .grid-slider__inner--full-bleed .grid-slider__track--slider {
    padding-inline: var(--gs-gutter-width, 0px);
    scroll-padding-inline-start: var(--gs-gutter-width, 0px);
  }

  /* ─── Arrows ─── */
  .grid-slider__arrows {
    display: none;
    align-items: center;
    justify-content: flex-end;
    gap: 8px;
    margin-block-start: 12px;
    padding-inline: var(--gs-gutter-width, 0px);
  }

  .grid-slider__arrows--visible {
    display: flex;
  }

  .grid-slider__btn[disabled] {
    opacity: 0.35;
    cursor: default;
    pointer-events: none;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Grid Slider",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "_card"
    },
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Desktop"
    },
    {
      "type": "checkbox",
      "id": "slider_desktop",
      "label": "Enable slider on desktop",
      "default": false
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "peek_desktop",
      "label": "Peek next card",
      "info": "Show a portion of the next card to hint at scrollability",
      "options": [
        { "value": "0", "label": "None" },
        { "value": "0.15", "label": "Small (15%)" },
        { "value": "0.25", "label": "Medium (25%)" },
        { "value": "0.4", "label": "Large (40%)" },
        { "value": "0.5", "label": "Half card (50%)" }
      ],
      "default": "0",
      "visible_if": "{{ section.settings.slider_desktop == true }}"
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "label": "Gap",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Tablet"
    },
    {
      "type": "checkbox",
      "id": "slider_tablet",
      "label": "Enable slider on tablet",
      "default": false
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "peek_tablet",
      "label": "Peek next card",
      "options": [
        { "value": "0", "label": "None" },
        { "value": "0.15", "label": "Small (15%)" },
        { "value": "0.25", "label": "Medium (25%)" },
        { "value": "0.4", "label": "Large (40%)" },
        { "value": "0.5", "label": "Half card (50%)" }
      ],
      "default": "0",
      "visible_if": "{{ section.settings.slider_tablet == true }}"
    },
    {
      "type": "range",
      "id": "gap_tablet",
      "label": "Gap",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "checkbox",
      "id": "slider_mobile",
      "label": "Enable slider on mobile",
      "default": true
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 1
    },
    {
      "type": "select",
      "id": "peek_mobile",
      "label": "Peek next card",
      "info": "Set to Large or Half card to achieve a 1.5-card feel on mobile",
      "options": [
        { "value": "0", "label": "None" },
        { "value": "0.15", "label": "Small (15%)" },
        { "value": "0.25", "label": "Medium (25%)" },
        { "value": "0.4", "label": "Large (40%)" },
        { "value": "0.5", "label": "Half card (50%)" }
