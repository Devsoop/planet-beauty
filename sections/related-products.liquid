{%- if section.settings.show_related_products  -%}
  <div class="related-products" data-related-products data-product-id="{{ product.id }}" data-limit="8">
    {%- if recommendations.products_count > 0 -%}
      <div data-related-container data-qty="{{recommendations.products_count }}">
        <div class="heading__wrapper">
          <h2 class="heading h1 highlight">{{ section.settings.heading }}</h2>
        </div>

        <div class="carousel carousel__mobile-half carousel__tablet-3 carousel__desktop-4" data-related-products-carousel data-flickity='{ "groupCells": "true", "cellAlign": "left", "imagesLoaded": "true", "percentPosition": "false", "adaptiveHeight": "true", "groupCells": "100%", "lazyLoad": "true" }'>
          {%- for product in recommendations.products limit: 8 -%}
              <div class="carousel__item">{% render 'product-card', product: product %}</div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Related Products",
  "settings": [
	{
      "type": "checkbox",
      "id": "show_related_products",
      "label": "Turn on related products",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Kinda Vibe"
    }
  ]
}
{% endschema %}