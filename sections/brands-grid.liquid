{% if section.settings.main_linklist %}
  {% render 'brands', menu: section.settings.main_linklist %}
{% endif %}

{% schema %}
  {
    "name": "Brands Grid",
    "settings": [
      {
        "type": "link_list",
        "id": "main_linklist",
        "label": "Menu",
        "default": "main-menu"
      }
    ]
  }
{% endschema %}